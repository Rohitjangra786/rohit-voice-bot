# ============================================================
# Rohit voice bot — environment variables
# Copy this file to ".env" and fill in your real values.
# Never commit the real .env to git.
# ============================================================

# --- The LLM (Rohit's brain) --------------------------------
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Speech to text -----------------------------------------
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=

# --- Text to speech -----------------------------------------
# Get from https://play.cartesia.ai
CARTESIA_API_KEY=
# Pick a warm male Indian-English voice in the Cartesia dashboard
# (https://play.cartesia.ai/voices — filter Language = "English (India)"
# or "Hindi" for a voice that also speaks Hindi/Hinglish cleanly), then
# paste its voice ID here. Test it reading the actual greeting line — you
# want a Delhi-leaning, polite, slightly warm male voice.
CARTESIA_VOICE_ID=

# --- Telephony (Twilio) -------------------------------------
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number, E.164 format, e.g. +12025550123
TWILIO_PHONE_NUMBER=

# --- Public address of server.py ----------------------------
# In development: run `ngrok http 8000` and paste the https URL here.
# In production: your server's public https domain.
# e.g. https://rohit-bot.ngrok.app   (no trailing slash)
PUBLIC_HOST=

# --- Human transfer target ----------------------------------
# The admission in-charge's phone number, E.164 format.
# When a caller asks for a human, Rohit transfers the live call here.
ADMISSION_INCHARGE_NUMBER=
